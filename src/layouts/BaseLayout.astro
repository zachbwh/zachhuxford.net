---
import { css } from "@styled-system/css";
import Navigation from "@components/Navigation.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const { title = "Zach Huxford", description = "SWE from NZ, based in London", ogImage, ogImageAlt } = Astro.props;

const bodyClass = css({
  backgroundColor: "background.main-accent",
  minHeight: "[100dvh]",
  position: "relative",
});

const navWrapperClass = css({
  maxWidth: "breakpoint-lg",
  marginInline: "auto",
  paddingInline: "5",
  sm: { paddingInline: "10" },
});

const mainWrapperClass = css({
  maxWidth: "breakpoint-lg",
  marginInline: "auto",
  paddingInline: "5",
  paddingBlock: "20",
  paddingBlockStart: "7",
  sm: {
    paddingInline: "10",
    paddingBlockStart: "20",
  },
});
---

<!doctype html>
<html lang="en" data-theme="purple">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inconsolata:wght@300..700&family=Karla:wght@300..700&family=Montserrat:wght@300..700&display=swap"
      rel="stylesheet"
    />
    <!-- Apply saved theme before first paint and before view transition snapshot -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem("theme");
        if (saved) document.documentElement.setAttribute("data-theme", saved);
        // Re-apply theme before the view transition reveals the new page
        if (typeof addEventListener !== "undefined") {
          addEventListener("pagereveal", function() {
            var s = localStorage.getItem("theme");
            if (s) document.documentElement.setAttribute("data-theme", s);
          });
        }
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <div class={navWrapperClass}>
      <Navigation />
    </div>
    <div class={mainWrapperClass}>
      <slot />
    </div>
  </body>
</html>
