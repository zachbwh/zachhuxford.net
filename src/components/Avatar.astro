---
import { cva, type RecipeVariantProps } from "@styled-system/css";

const avatarRecipe = cva({
  base: {
    borderRadius: "[50%]",
    display: "inline-block",
  },
  variants: {
    size: {
      sm: { width: "8", height: "8" },
      md: { width: "14", height: "14" },
      lg: { width: "20", height: "20" },
    },
  },
});

type AvatarVariants = RecipeVariantProps<typeof avatarRecipe>;
type SizeVariants = NonNullable<NonNullable<AvatarVariants>["size"]>;

interface Props {
  size: SizeVariants;
  src: string;
  alt?: string;
}

const { size, src, alt = "Avatar" } = Astro.props;
---

<img src={src} alt={alt} class={avatarRecipe({ size })} />
