---
import { Image } from "astro:assets";
import { cva, type RecipeVariantProps } from "@styled-system/css";

const avatarRecipe = cva({
  base: {
    borderRadius: "[50%]",
    display: "inline-block",
  },
  variants: {
    size: {
      sm: { width: "8", height: "8" },
      md: { width: "14", height: "14" },
      lg: { width: "20", height: "20" },
    },
  },
});

const sizeWidths = {
  sm: 32,
  md: 56,
  lg: 80,
} as const;

type AvatarVariants = RecipeVariantProps<typeof avatarRecipe>;
type SizeVariants = NonNullable<NonNullable<AvatarVariants>["size"]>;

interface Props {
  size: SizeVariants;
  src: ImageMetadata;
  alt?: string;
}

const { size, src, alt = "Avatar" } = Astro.props;
---

<Image
  src={src}
  alt={alt}
  width={sizeWidths[size]}
  height={sizeWidths[size]}
  format="avif"
  densities={[1, 2]}
  class={avatarRecipe({ size })}
/>
