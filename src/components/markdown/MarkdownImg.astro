---
import { Image } from "astro:assets";
import { css } from "@styled-system/css";
import { IMAGE_WIDTHS } from "../../consts";

interface Props {
  src: ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;

const className = css({
  width: "[100%]",
  height: "[auto]",
  borderRadius: "2",
});
---

<Image src={src} alt={alt} widths={[...IMAGE_WIDTHS]} sizes="auto" loading="lazy" class={className} />
