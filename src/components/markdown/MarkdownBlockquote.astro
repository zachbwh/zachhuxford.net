---
import { css } from "@styled-system/css";

const className = css({
  textStyle: "body",
  borderInlineStart: "[4px solid]",
  borderInlineStartColor: "foreground.secondary-accent",
  paddingInlineStart: "4",
  opacity: "[0.8]",
});
---

<blockquote class={className} {...Astro.props}>
  <slot />
</blockquote>
