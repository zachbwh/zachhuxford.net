---
import { css } from "@styled-system/css";
import { Palette } from "@lucide/astro";

const selectClass = css({
  padding: "2",
  borderRadius: "2",
  color: "foreground.on-main-accent",
  backgroundColor: "background.secondary",
  cursor: "pointer",
  textStyle: "body",
  appearance: "[base-select]",
  border: "[none]",
  outlineWidth: "0",
  transition: "[background]",
  transitionDuration: "100ms",
  _hover: {
    backgroundColor: "background.secondary-hover",
  },
  _active: {
    backgroundColor: "background.secondary-active",
  },
  width: "[min-content]",
  _focusVisible: {
    outlineWidth: "2",
    outlineStyle: "solid",
    outlineColor: "foreground.on-main-accent",
    outlineOffset: "[2px]",
  },
  "&::picker(select)": {
    appearance: "[base-select]",
    backgroundColor: "background.main-accent",
    border: "outline",
    borderRadius: "2",
    shadow: "lg",
    padding: "2",
    gap: "1",
    minWidth: "[120px]",
  },
  "& option": {
    padding: "2",
    borderRadius: "2",
    color: "foreground.on-main-accent",
    backgroundColor: "background.secondary",
  },
  "& option:hover": {
    backgroundColor: "background.secondary-hover",
  },
  "& option:focus": {
    backgroundColor: "background.secondary-hover",
  },
  "& option:checked": {
    // backgroundColor: "background.primary",
  },
  "& option::checkmark": {
    content: "['\\2713']",
  },
});
---

<select id="theme-select" class={selectClass} aria-label="Change theme">
  <button class={css({ display: "flex", alignItems: "center", gap: "1" })}>
    <Palette size={16} stroke-width={1.5} aria-hidden="true" />
    <selectedcontent class={css({ srOnly: true })} />
  </button>
  <option value="purple">Purple</option>
  <option value="dark">Dark</option>
</select>

<script>
  const select = document.getElementById("theme-select") as HTMLSelectElement;

  select.value = document.documentElement.getAttribute("data-theme") ?? "purple";

  select.addEventListener("change", () => {
    const theme = select.value;
    const apply = () => {
      document.documentElement.setAttribute("data-theme", theme);
      localStorage.setItem("theme", theme);
    };

    if (document.startViewTransition) {
      document.startViewTransition(apply);
    } else {
      apply();
    }
  });
</script>
