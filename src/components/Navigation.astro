---
import { css, cva } from "@styled-system/css";
import ThemeSwitcher from "./ThemeSwitcher.astro";

const navItems = [
  { label: "Home", href: "/" },
  { label: "My Story", href: "/my-story" },
  { label: "Music", href: "/music" },
  { label: "Blog", href: "/blog" },
];

const currentPath = Astro.url.pathname;

const navigation = css({
  width: "[100%]",
  paddingBlock: "4",
  display: "flex",
  justifyContent: "space-between",
  alignItems: "center",
});

const navigationList = css({
  display: "flex",
  listStyle: "none",
  margin: "0",
  gap: '4'
});

const navigationItem = css({
  display: "inline-block",
});

const navigationLink = cva({
  base: {
    borderRadius: "2",
    color: "foreground.on-main-accent",
    textStyle: "body",
    outlineWidth: "0",
    position: "relative",
    textUnderlineOffset: "4px",
    _hover: {
      textDecoration: "underline",
    },
    _focusVisible: {
      outline: 'none',
      _before: {
        content: '""',
        position: "absolute",
        inset: '-2',
        borderRadius: "[inherit]",
        outlineWidth: "2",
        outlineStyle: "solid",
        outlineColor: "foreground.on-main-accent",
      },
    },
  },
  variants: {
    active: {
      true: {
        textDecoration: "underline",
      },
    },
  },
});
---

<nav class={navigation}>
  <ul class={navigationList}>
    {
      navItems.map((item) => {
        const isActive = item.href === "/"
          ? currentPath === "/"
          : currentPath.startsWith(item.href);
        return (
          <li class={navigationItem}>
            <a href={item.href} class={navigationLink({ active: isActive })}>
              {item.label}
            </a>
          </li>
        );
      })
    }
  </ul>
  <ThemeSwitcher />
</nav>
