---
import { css } from "@styled-system/css";
import { stack } from "@styled-system/patterns";
import BaseLayout from "../layouts/BaseLayout.astro";
import Avatar from "../components/Avatar.astro";

const GRAVATAR_URL =
  "https://gravatar.com/avatar/4fe732c23f15dea9070cce32e4e3e0c23b333d83abca1bb77fb3792f91927966?s=300";

const sectionClass = stack({
  direction: "column",
  gap: "4",
  justifyContent: "center",
  color: "foreground.on-main-accent",
});

const bodyClass = css({ textStyle: "body" });
const accentClass = css({ color: "foreground.secondary-accent" });

const desktopHeadingClass = css({ textStyle: "display-lg", hideBelow: "sm" });
const desktopAvatarWrapperClass = css({
  display: "inline-block",
  verticalAlign: "baseline",
  paddingInlineStart: "2",
});

const mobileHeadingClass = css({ textStyle: "display-sm", hideFrom: "sm" });
const mobileAvatarWrapperClass = css({
  display: "inline-block",
  verticalAlign: "baseline",
  paddingInlineStart: "1",
});
---

<BaseLayout>
  <section class={sectionClass}>
    <p class={bodyClass}>It's me!</p>

    <!-- Desktop -->
    <h1 class={desktopHeadingClass}>
      Zach Huxford<span class={accentClass}>.</span>
      <span class={desktopAvatarWrapperClass}>
        <Avatar size="lg" src={GRAVATAR_URL} />
      </span>
    </h1>

    <!-- Mobile -->
    <h1 class={mobileHeadingClass}>
      Zach Huxford<span class={accentClass}>.</span>
      <span class={mobileAvatarWrapperClass}>
        <Avatar size="md" src={GRAVATAR_URL} />
      </span>
    </h1>

    <p class={bodyClass}>
      I'm a Software Developer from New Zealand.
    </p>
    <p class={bodyClass}>
      I like to spend my spare time browsing wikipedia, reading, listening to
      podcasts and music, and cooking. I'm particularly interested in full stack
      web development, graphic design and Linux.
    </p>
    <p class={bodyClass}>
      I care about my work having a positive impact on other people, which is
      why it is important to me that my work has a strong human component,
      whether it is by creating something useful or something beautiful.
    </p>
  </section>
</BaseLayout>
