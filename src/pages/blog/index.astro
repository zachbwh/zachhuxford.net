---
import { getCollection } from "astro:content";
import { css } from "@styled-system/css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";

const base = import.meta.env.BASE_URL;

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.data.publishedTime).getTime() -
    new Date(a.data.publishedTime).getTime()
);

const gridClass = css({
  display: "grid",
  gridTemplateColumns: "repeat(auto-fit, minmax(250px, 1fr))",
  columnGap: "6",
  rowGap: "10",
  listStyle: "none",
  padding: "0",
  margin: "0",
});

const fullWidthClass = css({ gridColumn: "1 / -1" });
const headingClass = css({ textStyle: "display-lg" });
const accentClass = css({ color: "foreground.secondary-accent" });
const autoColumnClass = css({ gridColumn: "auto" });
---

<BaseLayout title="Blog — Zach Huxford" description="Writing by Zach Huxford">
  <div>
    <ul class={gridClass}>
      <li class={fullWidthClass}>
        <h1 class={headingClass}>
          Blog Posts<span class={accentClass}>.</span>
        </h1>
      </li>
      {
        sortedPosts.map((post) => (
          <li class={autoColumnClass}>
            <BlogCard
              href={`${base}/blog/${post.slug}`}
              thumbnailSrc={post.data.thumbnail}
              title={post.data.title}
              subtitle={post.data.description}
              date={post.data.publishedTime}
              author={post.data.authors[0]}
            />
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
