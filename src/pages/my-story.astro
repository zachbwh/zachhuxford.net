---
import { css } from "@styled-system/css";
import { stack } from "@styled-system/patterns";
import BaseLayout from "../layouts/BaseLayout.astro";
import Avatar from "../components/Avatar.astro";

const GRAVATAR_URL =
  "https://gravatar.com/avatar/4fe732c23f15dea9070cce32e4e3e0c23b333d83abca1bb77fb3792f91927966?s=300";
---

<BaseLayout title="My Story — Zach Huxford" description="The story of Zach Huxford">
  <section
    class={stack({
      direction: "column",
      gap: "6",
      color: "foreground.on-main-accent",
    })}
  >
    <div class={css({ display: "flex", alignItems: "center", gap: "6" })}>
      <Avatar size="lg" src={GRAVATAR_URL} />
      <h1 class={css({ textStyle: "display-md", sm: { textStyle: "display-lg" } })}>
        My Story<span class={css({ color: "foreground.secondary-accent" })}>.</span>
      </h1>
    </div>

    <p class={css({ textStyle: "body" })}>
      Hey, I'm Zach — a Software Developer from New Zealand, currently based in London.
    </p>

    <p class={css({ textStyle: "body" })}>
      This page is a work in progress. Check back soon.
    </p>
  </section>
</BaseLayout>
