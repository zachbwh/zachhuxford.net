---
import { css } from "@styled-system/css";
import { stack } from "@styled-system/patterns";
import BaseLayout from "../layouts/BaseLayout.astro";
import Avatar from "../components/Avatar.astro";
import avatarSrc from "../assets/avatar.jpg";

const sectionClass = stack({
  direction: "column",
  gap: "6",
  color: "foreground.on-main-accent",
});

const headerClass = css({ display: "flex", alignItems: "center", gap: "6" });
const headingClass = css({ textStyle: { base: "display-sm", sm: "display-lg" } });
const accentClass = css({ color: "foreground.secondary-accent" });
const bodyClass = css({ textStyle: "body" });
---

<BaseLayout title="My Story — Zach Huxford" description="The story of Zach Huxford">
  <section class={sectionClass}>
    <div class={headerClass}>
      <Avatar size="lg" src={avatarSrc} />
      <h1 class={headingClass}>
        My Story<span class={accentClass}>.</span>
      </h1>
    </div>

    <p class={bodyClass}>
      Hey, I'm Zach — a Software Developer from New Zealand, currently based in London.
    </p>

    <p class={bodyClass}>
      This page is a work in progress. Check back soon.
    </p>
  </section>
</BaseLayout>
