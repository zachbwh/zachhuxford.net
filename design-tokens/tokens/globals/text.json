{
  "text": {
    "fonts": {
      "$type": "fontFamily",
      "$description": "Use font stacks generated by next.js. @TODO add a next.js transform group to keep a platform agnostic source of truth",
      "karla": {
        "$value": "var(--font-karla)"
      },
      "montserrat": {
        "$value": "var(--font-montserrat)"
      },
      "inconsolata": {
        "$value": "var(--font-inconsolata)"
      }
    },
    "sizes": {
      "$type": "fontSize",
      "display-2xl": {
        "$value": "{dimensions.20}"
      },
      "display-xl": {
        "$value": "{dimensions.17}"
      },
      "display-lg": {
        "$value": "{dimensions.14}"
      },
      "display-md": {
        "$value": "{dimensions.12}"
      },
      "display-sm": {
        "$value": "{dimensions.10}"
      },
      "display-xs": {
        "$value": "{dimensions.8}"
      },
      "heading-lg": {
        "$value": "{dimensions.7}"
      },
      "heading-md": {
        "$value": "{dimensions.6}"
      },
      "heading-sm": {
        "$value": "{dimensions.5}"
      },
      "body": {
        "$value": "{dimensions.4}"
      }
    },
    "weights": {
      "$type": "fontWeight",
      "light": {
        "$value": "300"
      },
      "regular": {
        "$value": "400"
      },
      "medium": {
        "$value": "500"
      },
      "semibold": {
        "$value": "600"
      },
      "bold": {
        "$value": "700"
      }
    },
    "lineHeights": {
      "$type": "number",
      "normal": {
        "$value": 1.2
      },
      "large": {
        "$value": 1.5
      }
    },
    "typography": {
      "$type": "typography",
      "display-2xl": {
        "$value": {
          "fontFamily": "{text.fonts.karla}",
          "fontWeight": "{text.weights.semibold}",
          "fontSize": "{text.sizes.display-2xl}",
          "lineHeight": "{text.lineHeights.normal}"
        }
      },
      "display-xl": {
        "$value": {
          "fontFamily": "{text.fonts.karla}",
          "fontWeight": "{text.weights.semibold}",
          "fontSize": "{text.sizes.display-xl}",
          "lineHeight": "{text.lineHeights.normal}"
        }
      },
      "display-lg": {
        "$value": {
          "fontFamily": "{text.fonts.karla}",
          "fontWeight": "{text.weights.semibold}",
          "fontSize": "{text.sizes.display-lg}",
          "lineHeight": "{text.lineHeights.normal}"
        }
      },
      "display-md": {
        "$value": {
          "fontFamily": "{text.fonts.karla}",
          "fontWeight": "{text.weights.semibold}",
          "fontSize": "{text.sizes.display-md}",
          "lineHeight": "{text.lineHeights.normal}"
        }
      },
      "display-sm": {
        "$value": {
          "fontFamily": "{text.fonts.karla}",
          "fontWeight": "{text.weights.semibold}",
          "fontSize": "{text.sizes.display-sm}",
          "lineHeight": "{text.lineHeights.normal}"
        }
      },
      "display-xs": {
        "$value": {
          "fontFamily": "{text.fonts.karla}",
          "fontWeight": "{text.weights.semibold}",
          "fontSize": "{text.sizes.display-xs}",
          "lineHeight": "{text.lineHeights.normal}"
        }
      },
      "heading-lg": {
        "$value": {
          "fontFamily": "{text.fonts.montserrat}",
          "fontWeight": "{text.weights.medium}",
          "fontSize": "{text.sizes.heading-lg}",
          "lineHeight": "{text.lineHeights.large}"
        }
      },
      "heading-md": {
        "$value": {
          "fontFamily": "{text.fonts.montserrat}",
          "fontWeight": "{text.weights.medium}",
          "fontSize": "{text.sizes.heading-md}",
          "lineHeight": "{text.lineHeights.large}"
        }
      },
      "heading-sm": {
        "$value": {
          "fontFamily": "{text.fonts.montserrat}",
          "fontWeight": "{text.weights.medium}",
          "fontSize": "{text.sizes.heading-sm}",
          "lineHeight": "{text.lineHeights.large}"
        }
      },
      "body": {
        "$value": {
          "fontFamily": "{text.fonts.montserrat}",
          "fontWeight": "{text.weights.regular}",
          "fontSize": "{text.sizes.body}",
          "lineHeight": "{text.lineHeights.large}"
        }
      },
      "code": {
        "$value": {
          "fontFamily": "{text.fonts.inconsolata}",
          "fontWeight": "{text.weights.regular}",
          "fontSize": "{text.sizes.body}",
          "lineHeight": "{text.lineHeights.large}"
        }
      },
      "inherit": {
        "$value": {
          "fontFamily": "inherit",
          "fontWeight": "inherit",
          "fontSize": "inherit",
          "lineHeight": "inherit"
        }
      }
    }
  }
}
