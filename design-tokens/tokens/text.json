{
  "text": {
    "fonts": {
      "$type": "fontFamily",
      "$description": "Use font stacks generated by next.js. @TODO add a next.js transform group to keep a platform agnostic source of truth",
      "karla": {
        "$value": "var(--font-karla)"
      },
      "montserrat": {
        "$value": "var(--font-montserrat)"
      },
      "inconsolata": {
        "$value": "var(--font-inconsolata)"
      }
    },
    "sizes": {
      "$type": "fontSize",
      "display": {
        "$value": "{dimensions.20}"
      },
      "heading": {
        "$value": "{dimensions.7}"
      },
      "body": {
        "$value": "{dimensions.4}"
      }
    },
    "weights": {
      "$type": "fontWeight",
      "light": {
        "$value": "thin"
      },
      "regular": {
        "$value": "regular"
      },
      "bold": {
        "$value": "extra-bold"
      }
    },
    "lineHeights": {
      "$type": "number",
      "normal": {
        "$value": 1.2
      },
      "large": {
        "$value": 1.5
      }
    },
    "typography": {
      "$type": "typography",
      "display": {
        "$value": {
          "fontFamily": "{text.fonts.karla}",
          "fontWeight": "{text.weights.bold}",
          "fontSize": "{text.sizes.display}",
          "lineHeight": "{text.lineHeights.large}"
        }
      },
      "heading": {
        "$value": {
          "fontFamily": "{text.fonts.montserrat}",
          "fontWeight": "{text.weights.bold}",
          "fontSize": "{text.sizes.heading}",
          "lineHeight": "{text.lineHeights.large}"
        }
      },
      "body": {
        "$value": {
          "fontFamily": "{text.fonts.montserrat}",
          "fontWeight": "{text.weights.regular}",
          "fontSize": "{text.sizes.body}",
          "lineHeight": "{text.lineHeights.normal}"
        }
      },
      "code": {
        "$value": {
          "fontFamily": "{text.fonts.inconsolata}",
          "fontWeight": "{text.weights.regular}",
          "fontSize": "{text.sizes.body}",
          "lineHeight": "{text.lineHeights.normal}"
        }
      }
    }
  }
}
