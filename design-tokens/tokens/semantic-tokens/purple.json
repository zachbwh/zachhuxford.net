{
  "semantic-tokens": {
    "colors": {
      "foreground": {
        "on-main-accent": {
          "$type": "color",
          "$value": "{colors.white}"
        },
        "secondary-accent": {
          "$type": "color",
          "$value": "{colors.emerald.700}"
        }
      },
      "background": {
        "main-accent": {
          "$type": "color",
          "$value": "{colors.mauve.700}"
        },
        "primary": {
          "$type": "color",
          "$value": "{colors.mauve.100}"
        },
        "primary-hover": {
          "$type": "color",
          "$value": "{colors.mauve.200}"
        },
        "primary-active": {
          "$type": "color",
          "$value": "{colors.mauve.300}"
        }
      }
    },
    "borders": {
      "outline": {
        "$type": "border",
        "$value": "{dimensions.1} {borders.styles.solid} {colors.mauve.400}"
      }
    }
  }
}
