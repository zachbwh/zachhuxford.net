{
  "semantic-tokens": {
    "colors": {
      "foreground": {
        "on-main-accent": {
          "$type": "color",
          "$value": "{colors.white}"
        },
        "secondary-accent": {
          "$type": "color",
          "$value": "{colors.emerald.700}"
        }
      },
      "background": {
        "main-accent": {
          "$type": "color",
          "$value": "{colors.slate.900}"
        }
      }
    }
  }
}
