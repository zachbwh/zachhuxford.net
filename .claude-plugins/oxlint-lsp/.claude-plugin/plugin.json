{
  "name": "oxlint-lsp",
  "description": "Oxlint language server providing lint diagnostics.",
  "version": "1.0.0",
  "lspServers": {
    "oxlint": {
      "command": "npx",
      "args": ["oxlint", "--lsp"],
      "extensionToLanguage": {
        ".astro": "astro",
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    }
  }
}
